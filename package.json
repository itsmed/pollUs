{
  "name": "pollus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "docker compose up db -d --wait && concurrently --names 'server,client' --prefix-colors 'yellow,cyan' 'pnpm --filter server dev' 'pnpm --filter client dev'",
    "dev:docker": "docker compose up --build",
    "dev:down": "docker compose down",
    "db:up": "docker compose up db -d --wait",
    "db:down": "docker compose stop db",
    "db:migrate": "bash scripts/migrate.sh",
    "db:migrate:dry-run": "bash scripts/migrate.sh --dry-run",
    "db:reset": "docker compose down -v && docker compose up db -d --wait",
    "build": "pnpm --filter client build",
    "lint": "pnpm --filter client lint",
    "install": "pnpm install --recursive"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "workspaces": [
    "client",
    "server"
  ]
}

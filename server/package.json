{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "tsx ./bin/www.ts",
    "dev": "NODE_ENV=development ./node_modules/.bin/nodemon --exec 'tsx --env-file=.env.development.local' ./bin/www.ts",
    "build": "tsc",
    "db:setup": "tsx --env-file=.env.development.local db/setup.js",
    "db:seed-votes": "node --env-file=.env.development.local db/seedVotes.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint ."
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "coverageDirectory": "coverage",
    "coverageReporters": ["lcov", "text-summary"],
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.d.ts",
      "!**/*.test.ts",
      "!tests/**",
      "!bin/**"
    ]
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "express": "~4.16.1",
    "morgan": "~1.9.1",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.2",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "globals": "^15",
    "@types/cookie-parser": "^1",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4",
    "@types/express": "^4",
    "@types/jest": "^29",
    "@types/morgan": "^1",
    "@types/node": "^20",
    "@types/passport": "^1",
    "@types/passport-google-oauth20": "^2",
    "@types/pg": "^8",
    "eslint": "^9",
    "eslint-plugin-n": "^17",
    "eslint-plugin-security": "^3",
    "eslint-plugin-unicorn": "^57",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8"
  }
}
